# Groq — fast logic (https://console.groq.com/keys)
GROQ_API_KEY=
# llama-3.1-70b-versatile is decommissioned; use llama-3.3-70b-versatile
GROQ_MODEL=llama-3.3-70b-versatile

# Google Gemini — large code context (https://aistudio.google.com/apikey)
GEMINI_API_KEY=
# gemini-1.5-flash is retired; gemini-2.5-flash avoids 2.0 quota limits
GEMINI_MODEL=gemini-2.5-flash

# GitHub OAuth — Phase 6 deployment (https://github.com/settings/developers)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://127.0.0.1:8000/auth/callback
FRONTEND_URL=http://localhost:5173
