# --- LLM providers ---
GROQ_API_KEY=
LLM_MODEL_GROQ=llama-3.3-70b-versatile

GEMINI_API_KEY=
LLM_MODEL_GEMINI=gemini-1.5-flash

# --- Application URLs ---
SENTINEL_APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173

# --- GitHub OAuth (https://github.com/settings/developers) ---
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Optional override; defaults to SENTINEL_APP_URL/auth/callback
GITHUB_REDIRECT_URI=

# --- Ephemeral workspace (never store scans on user home paths) ---
WORKSPACE_STORAGE_TYPE=local
# Override root (e.g. /dev/shm/codesentinel for tmpfs RAM disk)
SENTINEL_WORKSPACE_ROOT=
SCAN_WORKSPACE_TTL_SECONDS=3600
WORKSPACE_GC_INTERVAL_SECONDS=1800

# --- Production runtime ---
ENVIRONMENT=development
LOG_LEVEL=INFO

# --- Git deploy identity ---
GIT_DEPLOY_USER_NAME=CodeSentinel-Bot
GIT_DEPLOY_USER_EMAIL=sentinel@codesentinel.local
GIT_DEPLOY_COMMIT_MESSAGE=CodeSentinel Security Audit: Clean Snapshot
